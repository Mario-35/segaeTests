    {
      "id": "E.1.1",
      "title_en": "Balanced strategy between farmer income and investment",
      "title": "Répartition équilibrée de la marge entre revenu de l'agriculteur et investissement",
      "description_en": "Farm profit is equally shared between farmer income and investment capacity.",
      "description": "Le bénéfice agricole est partagé à parts égales entre les revenus et les capacités d'investissement de l’agriculteur."
    },
    {
      "id": "E.1.2",
      "title_en": "Investment-oriented strategy",
      "title": "Stratégie axée sur l'investissement",
      "description_en": "Farm profit is 80% distributed to investment capacity.",
      "description": "Les bénéfices agricoles sont consacrés à 80% aux capacités d'investissement."
    },
    {
      "id": "E.1.3",
      "title_en": "Income-oriented strategy",
      "title": "Stratégie axée sur les revenus",
      "description_en": "Farm profit is 80% distributed to farmer income.",
      "description": "Les bénéfices agricoles sont consacrés à 80% aux revenus de l’agriculteur."
    },
    {
      "id": "G.1.1",
      "title_en": "Conventional farming",
      "title": "Agriculture conventionnelle",
      "description_en": "It corresponds to the most widespread farm management, with no particular specifications (except the compliance with the Good Agricultural and Environmental conditions of the CAP). Input and output prices are 25% lower than in organic farming.",
      "description": "Elle correspond à la gestion agricole la plus répandue, sans cahier des charges particulier (sauf le respect des bonnes conditions agricoles et environnementales de la PAC). Les prix des intrants et des extrants sont inférieurs de 25 % à ceux de l'agriculture biologique."
    },
    {
      "id": "G.1.2",
      "title_en": "Organic farming",
      "title": "Agriculture biologique",
      "description_en": "Specifications of organic farming rely mainly on no chemical input use. Input and output prices are 25% higher in conventional farming.",
      "description": "Le cahier des charges de l'agriculture biologique repose principalement sur l'absence d'utilisation de produits chimiques. Les prix des intrants et des extrants sont supérieurs de 25 % à ceux de l'agriculture biologique."
    },
    {
      "id": "A.1.1",
      "title_en": "Cattle breed is Holstein",
      "title": "Race Holstein",
      "description_en": "Holstein is a breed of dairy cattle used for high milk production.",
      "description": "La Holstein est une race de bovins laitiers utilisée pour une production laitière intensive."
    },
    {
      "id": "A.1.2",
