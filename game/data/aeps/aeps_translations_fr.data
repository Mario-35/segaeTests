  "data": [
    {
      "id": "C.1.1",
      "title_en": "Conventional tillage",
      "title": "Travail du sol conventionel",
      "description_en": "The “traditional” method of farming in which soil is prepared for planting by completely inverting it with a moldboard plow.",
      "description": "Méthode agricole « traditionnelle » dans laquelle le sol est préparé à être planté par un retournement complet à l'aide d'une charrue à versoirs."
    },
    {
      "id": "C.1.2",
      "title_en": "Reduced tillage",
      "title": "Travail réduit du sol",
      "description_en": "Use of only superficial tillage without soil inversion.",
      "description": "Travail du sol uniquement superficiel, sans retournement."
    },
    {
      "id": "C.1.3",
      "title_en": "No tillage",
      "title": "Semis direct",
      "description_en": "Planting of crops directly (no tillage) in preceding cover crop (living or destroyed, i.e. mulched) or crop residues.",
      "description": "Semis direct (sans travail du sol) dans la culture de couverture précédente (vivante ou détruite, c'est-à-dire paillée) ou dans les résidus de culture."
    },
    {
      "id": "C.2.1",
      "title_en": "Fall cover crop destructed before winter",
      "title": "Culture intermédiaire détruite à l'automne",
      "description_en": "The cover crop is terminated before winter and the soil is left bare until the spring crop is well established.",
      "description": "La culture de couverture est terminée avant l'hiver et le sol est laissé nu jusqu'à ce que la culture de printemps soit bien établie."
    },
    {
      "id": "C.2.2",
      "title_en": "Fall cover crop destructed early spring",
      "title": "Culture intermédiaire détruite au printemps",
      "description_en": "The fall cover crop is left during winter, covering the soil and is terminated early spring.",
      "description": "La culture de couverture d'automne est laissée pendant l'hiver, elle recouvre les sols et disparaît au début du printemps."
    },
    {
      "id": "C.2.3",
      "title_en": "Permanent soil cover",
      "title": "Couverture permanente du sol",
      "description_en": "Implementing this practice means that the soil is never left bare across the whole rotation.",
      "description": "L'application de cette pratique signifie que le sol n’est jamais laissé à nu sur l'ensemble de la rotation."
    },
    {
      "id": "C.3.1",
      "title_en": "Straw removal",
      "title": "Export des pailles",
      "description_en": "Crop residues are exported from the crop system and used for livestock bedding and/or exported from the farm by selling it.",
      "description": "Les résidus de culture sont évacués du système de culture et utilisés pour la litière du bétail et/ou sortis de l'exploitation agricole par le biais de la vente."
    },
    {
      "id": "C.3.2",
      "title_en": "Straw left on soil",
      "title": "Pailles laissées au sol",
      "description_en": "Crop residues are left on the soil and are either incorporated into the soil when tilling or are left as mulch when implementing direct seeding.",
      "description": "Les résidus de culture sont laissés sur le sol et sont soit incorporés dans celui-ci lors du labourage, soit laissés comme paillis lors de la mise en œuvre d’un semis direct."
    },
    {
      "id": "C.4.1",
      "title_en": "On-farm organic fertilizers + input of mineral fertilizer",
      "title": "Effluents d'élevage + apport d'engrais minéraux",
      "description_en": "The slurry and/or manure produced by animals is used as organic fertilizer and completed by mineral fertiliser.",
      "description": "Le lisier et/ou le fumier produit par les animaux est utilisé comme engrais organique et complété par un engrais minéral."
    },
    {
      "id": "C.4.2",
      "title_en": "On-farm organic fertilizers only",
      "title": "Effluents d'élevage uniquement",
      "description_en": "The slurry and/or manure produced by animals is used as organic fertilizer and not complemented.",
      "description": "Le lisier et/ou le fumier produit par les animaux est utilisé comme engrais organique et n’est pas complété."
    },
    {
      "id": "C.5.1",
      "title_en": "Systematic use of chemical fungicides",
      "title": "Utilisation systématique de fongicides",
      "description_en": "Chemical fungicides are systematically used. ",
      "description": "Des fongicides chimiques sont systématiquement utilisés. "
    },
    {
      "id": "C.5.2",
      "title_en": "Sound approach of chemical fungicides",
      "title": "Utilisation raisonnée des fongicides",
      "description_en": "The use of chemical fungicides whenever and only if it is absolutely required.",
      "description": "Utilisation de fongicides chimiques chaque fois et seulement s’ils sont absolument nécessaires."
    },
    {
      "id": "C.5.3",
      "title_en": "Biocontrol products against diseases",
      "title": "Utilisation de produits de biocontrôle contre les maladies",
      "description_en": "‘Integrated pest management’ strategy without chemicals.",
      "description": "Stratégie de « lutte intégrée contre les parasites » sans produits chimiques."
    },
    {
      "id": "C.5.4",
      "title_en": "No direct protection against diseases",
      "title": "Aucun produit n'est utilisé contre les maladies",
      "description_en": "No fungicide is applied.",
      "description": "Aucun fongicide n'est utilisé."
    },
    {
      "id": "C.6.1",
      "title_en": "Systematic and sole use of chemical herbicides",
      "title": "Utilisation systématique d'herbicides",
      "description_en": "Chemical herbicides are systematically used.",
      "description": "Des herbicides chimiques sont systématiquement utilisés."
    },
    {
      "id": "C.6.2",
      "title_en": "Sound approach of chemical herbicides + mechanical weed control",
      "title": "Utilisation raisonnée d'herbicides et désherbage mécanique",
      "description_en": "The use of chemical herbicides whenever and only if it is absolutely required.",
      "description": "Utilisation d’herbicides chimiques chaque fois que et seulement s’ils sont absolument nécessaires."
    },
    {
      "id": "C.6.3",
      "title_en": "Sole use of mechanical weed control",
      "title": "Désherbage mécanique uniquement",
      "description_en": "No herbicide is applied, weed populations are managed through physical methods (e.g. hoeing, harrowing).",
      "description": "Aucun herbicide n'est appliqué, les mauvaises herbes sont gérées par des méthodes physiques (par ex. binage, hersage)."
    },
    {
      "id": "C.7.1",
      "title_en": "Systematic use of chemical insecticides / molluscicides / nematicides",
      "title": "Utilisation systématique d'insecticides / molluscicides / nématicides",
      "description_en": "Chemical insecticides / molluscicides / nematicides are systematically used to avoid pests, even if the pressure is low.",
      "description": "Des insecticides / molluscicides / nématicides chimiques sont systématiquement utilisés pour éviter les parasites, même si la menace est faible."
    },
    {
      "id": "C.7.2",
      "title_en": "Sound approach of chemical insecticides / molluscicides / nematicides",
      "title": "Utilisation raisonnée des insecticides / molluscicides / nématicides",
      "description_en": "Chemical insecticides / molluscicides / nematicides  are applied only if pests are monitored in the field and sprays or other control methods are carried out only when the action threshold is exceeded (Integrated Pest Management).",
      "description": "Les insecticides / molluscicides / nématicides chimiques ne sont utilisés que si les parasites sont surveillés sur le terrain et les pulvérisations ou autres méthodes de lutte ne sont mises en œuvre que lorsque le seuil d'action est dépassé (lutte intégrée contre les parasites)."
    },
    {
      "id": "C.7.3",
      "title_en": "Biocontrol products (incl. pyrethrin) and other natural control techniques against pests",
      "title": "Utilisation de produits de biocontrôle et autres techniques naturelles de lutte contre les parasites",
      "description_en": "Biocontrol products / biopesticides will be applied using a sprayer.",
      "description": "Les produits de biocontrôle / biopesticides seront appliqués à l'aide d'un pulvérisateur."
    },
    {
      "id": "C.7.4",
      "title_en": "No direct protection against animal pests",
      "title": "Aucun produit n'est utilisé contre les parasites",
      "description_en": "No Insecticide / Molluscicide / Nematicide is applied.",
      "description": "Aucun insecticide / molluscicide / nématicide n'est appliqué."
    },
    {
      "id": "C.8.1",
      "title_en": "High yielding cultivars",
      "title": "Variétés productives",
      "description_en": "Use of one cultivar selected for its high yield in controled conditions.",
      "description": "Utilisation d'une variété sélectionnée pour son rendement élevé dans des conditions contrôlées."
    },
    {
      "id": "C.8.2",
      "title_en": "Resistant cultivars and/or mix of varieties",
      "title": "Variétés résistantes et/ou mélange de variétés",
      "description_en": "Use of one or more cultivars selected for their resistance/tolerance to pests and diseases, but with lower yield in controled conditions.",
      "description": "Utilisation d'un ou plusieurs cultivars sélectionnés pour leur résistance/tolérance aux parasites et aux maladies, mais avec un rendement plus faible dans des conditions contrôlées."
    },
    {
      "id": "C.9.1",
      "title_en": "Temporary grassland composed of grass",
      "title": "Prairie temporaire composée de graminées uniquement",
      "description_en": "Land on which the vegetation is dominated by grass such as perennial ryegrass or sheep's fescue.",
      "description": "Terrain sur lequel la végétation est dominée par l'herbe, comme l'ivraie vivace ou la fétuque ovine."
    },
    {
      "id": "C.9.2",
      "title_en": "Temporary grassland composed of simple grass/legume mixtures",
      "title": "Prairie temporaire composée d’une graminée et d’une légumineuse",
      "description_en": "Land on which the vegetation is dominated by two species, one grass and one legume such as perennial ryegrass and white clover.",
      "description": "Terrain sur lequel la végétation est dominée par deux espèces, une graminée et une plante, comme l’ivraie vivace et le trèfle blanc."
    },
    {
      "id": "C.9.3",
      "title_en": "Temporary grassland composed of complex grass/legume mixtures",
      "title": "Prairie temporaire composée d'un mélange complexe d'espèces (graminées, légumineuses, autres)",
      "description_en": "Land on which the vegetation is dominated by various species, grasses, legumes, etc.",
      "description": "Terrain sur lequel la végétation est dominée par diverses espèces, herbes, plantes, etc."
    },
    {
      "id": "C.10.1",
      "title_en": "No permanent grassland",
      "title": "Pas de prairie permanente",
      "description_en": "No permanent grassland on the farm.",
      "description": "Pas de prairies permanentes sur l’exploitation."
    },
    {
      "id": "C.10.2",
      "title_en": "Permanent grassland occupy a small percentage of the farm area",
      "title": "Les prairies permanentes occupent un faible pourcentage de l'assolement",
      "description_en": "Permanent grassland occupy 10% of farm area. It can be used to feed livestock and promote biodiversity.",
      "description": "Les prairies permanentes occupe 10% de la surface agricole. Elles peuvent être utilisées pour nourrir le bétail et promouvoir la biodiversité."
    },
    {
      "id": "C.10.3",
      "title_en": "Permanent grassland occupy a high percentage of the farm area",
      "title": "Les prairies permanentes occupent un pourcentage élevé de l'assolement",
      "description_en": "Permanent grassland occupy 20% of farm area. It can be used to feed livestock and promote biodiversity.",
      "description": "Les prairies permanentes occupent 20% de la surface agricole. Elles peuvent être utilisées pour nourrir le bétail et promouvoir la biodiversité."
    },
    {
      "id": "C.11.1",
      "title_en": "Sole crops",
      "title": "Cultures seules",
      "description_en": "Each crop is grown alone in the field.",
      "description": "Une seule culture est pratiquée dans chaque champ."
    },
    {
      "id": "C.11.2",
      "title_en": "Wheat/pea intercrops",
      "title": "Association blé/pois",
      "description_en": "Coexistence of the two crops (wheat, pea) on the same field at the same time. Yield of the intercrop will be higher than the average of individual crops on the same area. Intercrops can be valorized as animal feeding. Selling the crops will require additional sorting costs (not considered in the game).",
      "description": "Coexistence des deux cultures (blé, pois) dans le même champ en même temps. Le rendement de la culture en association sera supérieur à la moyenne des monocultures sur la même superficie. Les cultures en association peuvent être utilisées pour l'alimentation des animaux. La vente des récoltes entraînera des coûts de triage supplémentaires (non pris en compte dans le jeu)."
    },
