  "data": [
    {
      "id": "C.1.1",
      "title_en": "Conventional tillage",
      "title": "Konwencjonalna orka (CT)",
      "description_en": "The “traditional” method of farming in which soil is prepared for planting by completely inverting it with a moldboard plow.",
      "description": "„Tradycyjny” sposób uprawy roli, w którym gleba jest przygotowywana do siewu poprzez całkowite odwrócenie przy pomocy pługa lemieszowego."
    },
    {
      "id": "C.1.2",
      "title_en": "Reduced tillage",
      "title": "Ograniczona orka (RT)",
      "description_en": "Use of only superficial tillage without soil inversion.",
      "description": "Stosowanie wyłącznie powierzchniowej uprawy roli bez odwracania gleby."
    },
    {
      "id": "C.1.3",
      "title_en": "No tillage",
      "title": "Brak orki (NT)",
      "description_en": "Planting of crops directly (no tillage) in preceding cover crop (living or destroyed, i.e. mulched) or crop residues.",
      "description": "Wsiewka  (bez orki) w roślinność okrywową (rosnącą lub skoszoną, t.j. ściółkowanie) lub w resztki pożniwne."
    },
    {
      "id": "C.2.1",
      "title_en": "Fall cover crop destructed before winter",
      "title": "Jesienne rośliny okrywowe usunięte przed zimą",
      "description_en": "The cover crop is terminated before winter and the soil is left bare until the spring crop is well established.",
      "description": "Roślinność okrywowa zostaje usunięta przed zimą i gleba pozostaje odkryta do czasu wzejścia upraw jarych."
    },
    {
      "id": "C.2.2",
      "title_en": "Fall cover crop destructed early spring",
      "title": "Jesienne rośliny okrywowe usunięte wczesną wiosną",
      "description_en": "The fall cover crop is left during winter, covering the soil and is terminated early spring.",
      "description": "Jesienna roślinność okrywowa pozostaje na zimę, pokrywając glebę, i zostaje usunięta wczesną wiosną."
    },
    {
      "id": "C.2.3",
      "title_en": "Permanent soil cover",
      "title": "Stałe pokrycie gleby",
      "description_en": "Implementing this practice means that the soil is never left bare across the whole rotation.",
      "description": "Wdrożenie tej praktyki oznacza, że gleba nigdy nie jest odkryta."
    },
    {
      "id": "C.3.1",
      "title_en": "Straw removal",
      "title": "Słoma usunięta z pola",
      "description_en": "Crop residues are exported from the crop system and used for livestock bedding and/or exported from the farm by selling it.",
      "description": "Resztki pożniwne są usuwane z pól i wykorzystywane jako ściółka dla bydła i/lub sprzedawane przez gospodarstwo rolne."
    },
    {
      "id": "C.3.2",
      "title_en": "Straw left on soil",
      "title": "Słoma pozostawiona na polu",
      "description_en": "Crop residues are left on the soil and are either incorporated into the soil when tilling or are left as mulch when implementing direct seeding.",
      "description": "Resztki pożniwne pozostają na glebie i są albo przyorywane albo stanowią ściółkę w czasie siewu bezpośredniego."
    },
    {
      "id": "C.4.1",
      "title_en": "On-farm organic fertilizers + input of mineral fertilizer",
      "title": "Nawozy naturalne z fermy + nawóz mineralny",
      "description_en": "The slurry and/or manure produced by animals is used as organic fertilizer and completed by mineral fertiliser.",
      "description": "Gnojowica i/lub obornik wytwarzany przez zwierzęta jest wykorzystywany jako nawóz organiczny z dodatkiem w postaci nawozu mineralnego."
    },
    {
      "id": "C.4.2",
      "title_en": "On-farm organic fertilizers only",
      "title": "Tylko nawozy naturalne z fermy ",
      "description_en": "The slurry and/or manure produced by animals is used as organic fertilizer and not complemented.",
      "description": "Gnojowica i/lub obornik wytwarzany przez zwierzęta jest wykorzystywany jako nawóz organiczny bez dodatków."
    },
    {
      "id": "C.5.1",
      "title_en": "Systematic use of chemical fungicides",
      "title": "Systematyczne użycie chemicznych środków grzybobójczych",
      "description_en": "Chemical fungicides are systematically used. ",
      "description": "Chemiczne środki grzybobójcze są systematycznie stosowane. "
    },
    {
      "id": "C.5.2",
      "title_en": "Sound approach of chemical fungicides",
      "title": "Chemiczne środki grzybobójcze tylko w razie konieczności",
      "description_en": "The use of chemical fungicides whenever and only if it is absolutely required.",
      "description": "Chemiczne środki grzybobójcze są stosowane wyłącznie wówczas, gdy jest to bezwzględnie konieczne. "
    },
    {
      "id": "C.5.3",
      "title_en": "Biocontrol products against diseases",
      "title": "Środki biologiczne do ochrony przed chorobami",
      "description_en": "‘Integrated pest management’ strategy without chemicals.",
      "description": "Strategia „zintegrowanej ochrony przed szkodnikami” bez środków chemicznych."
    },
    {
      "id": "C.5.4",
      "title_en": "No direct protection against diseases",
      "title": "Brak bezpośredniej ochrony przed chorobami",
      "description_en": "No fungicide is applied.",
      "description": "Nie są stosowane żadne środki grzybobójcze."
    },
    {
      "id": "C.6.1",
      "title_en": "Systematic and sole use of chemical herbicides",
      "title": "Systematyczne użycie herbicydów chemicznych",
      "description_en": "Chemical herbicides are systematically used.",
      "description": "Chemiczne środki chwastobójcze są stosowane systematycznie."
    },
    {
      "id": "C.6.2",
      "title_en": "Sound approach of chemical herbicides + mechanical weed control",
      "title": "Herbicydy chemiczne tylko w razie konieczności + odchwaszczanie mechaniczne",
      "description_en": "The use of chemical herbicides whenever and only if it is absolutely required.",
      "description": "Chemiczne środki chwastobójcze są stosowane wyłącznie wówczas, gdy jest to bezwzględnie konieczne."
    },
    {
      "id": "C.6.3",
      "title_en": "Sole use of mechanical weed control",
      "title": "Tylko mechaniczne odchwaszczanie",
      "description_en": "No herbicide is applied, weed populations are managed through physical methods (e.g. hoeing, harrowing).",
      "description": "Nie są stosowane żadne herbicydy, populacja chwastów jest kontrolowana metodami fizycznymi (np. gracowanie, bronowanie)."
    },
    {
      "id": "C.7.1",
      "title_en": "Systematic use of chemical insecticides / molluscicides / nematicides",
      "title": "Systematyczne użycie chemicznych środków owadobójczych / mięczakobójczych / nicieniobójczych",
      "description_en": "Chemical insecticides / molluscicides / nematicides are systematically used to avoid pests, even if the pressure is low.",
      "description": "Dla uniknięcia szkodników systematycznie stosowane są chemiczne środki owadobójcze / mięczakobójcze / nematocydy, nawet przy niewielkiej presji."
    },
    {
      "id": "C.7.2",
      "title_en": "Sound approach of chemical insecticides / molluscicides / nematicides",
      "title": "Chemiczne środki owadobójcze / mięczakobójcze / nicieniobójcze tylko w razie konieczności",
      "description_en": "Chemical insecticides / molluscicides / nematicides  are applied only if pests are monitored in the field and sprays or other control methods are carried out only when the action threshold is exceeded (Integrated Pest Management).",
      "description": "Chemiczne środki owadobójcze / mięczakobójcze / nematocydy są stosowane wyłącznie, jeżeli szkodniki są monitorowane w polu, zaś opryski lub inne metody ich zwalczania są realizowane wyłącznie po przekroczeniu progu działania (zintegrowana ochrona przed szkodnikami)."
    },
    {
      "id": "C.7.3",
      "title_en": "Biocontrol products (incl. pyrethrin) and other natural control techniques against pests",
      "title": "Środki biologiczne (w tym pyretryna) i inne metody naturalnej kontroli szkodników",
      "description_en": "Biocontrol products / biopesticides will be applied using a sprayer.",
      "description": "Środki kontroli biologicznej / biopestycydy będą stosowane przy użyciu rozpylacza."
    },
    {
      "id": "C.7.4",
      "title_en": "No direct protection against animal pests",
      "title": "Brak bezpośredniej ochrony przed owadami/ mięczakami / nicieniami",
      "description_en": "No Insecticide / Molluscicide / Nematicide is applied.",
      "description": "Nie są stosowane żadne środki owadobójcze / mięczakobójcze / nematocydy."
    },
    {
      "id": "C.8.1",
      "title_en": "High yielding cultivars",
      "title": "Wysokowydajne odmiany uprawne",
      "description_en": "Use of one cultivar selected for its high yield in controled conditions.",
      "description": "Stosowanie jednej odmiany uprawnej wybranej ze względu na jej wysoką wydajność w kontrolowanych warunkach."
    },
    {
      "id": "C.8.2",
      "title_en": "Resistant cultivars and/or mix of varieties",
      "title": "Odporne odmiany uprawne i/lub mieszanka odmian",
      "description_en": "Use of one or more cultivars selected for their resistance/tolerance to pests and diseases, but with lower yield in controled conditions.",
      "description": "Stosowanie jednej lub więcej odmian uprawnych wybranych ze względu na ich odporność/tolerancję na szkodniki i choroby, ale o mniejszej wydajności w kontrolowanych warunkach."
    },
    {
      "id": "C.9.1",
      "title_en": "Temporary grassland composed of grass",
      "title": "Krótkotrwałe użytki zielone złożone z traw",
      "description_en": "Land on which the vegetation is dominated by grass such as perennial ryegrass or sheep's fescue.",
      "description": "Teren, na którym roślinność jest zdominowana przez trawy takie, jak życica trwała lub kostrzewa owcza."
    },
    {
      "id": "C.9.2",
      "title_en": "Temporary grassland composed of simple grass/legume mixtures",
      "title": "Krótkotrwałe użytki zielone: trawa i mieszanka roślin strączkowych",
      "description_en": "Land on which the vegetation is dominated by two species, one grass and one legume such as perennial ryegrass and white clover.",
      "description": "Teren, na którym roślinność jest zdominowana przez dwa gatunki, jedną trawę i jedną roślinę strączkową, jak życica trwała i koniczyna biała."
    },
    {
      "id": "C.9.3",
      "title_en": "Temporary grassland composed of complex grass/legume mixtures",
      "title": "Krótkotrwałe użytki zielone mieszanka traw i mieszanka roślin strączkowych",
      "description_en": "Land on which the vegetation is dominated by various species, grasses, legumes, etc.",
      "description": "Teren, na którym roślinność jest zdominowana przez różne gatunki, trawy, rośliny strączkowe, itp."
    },
    {
      "id": "C.10.1",
      "title_en": "No permanent grassland",
      "title": "Brak trwałych użytków zielonych",
      "description_en": "No permanent grassland on the farm.",
      "description": "Brak trwałych użytków zielonych w gospodarstwie."
    },
    {
      "id": "C.10.2",
      "title_en": "Permanent grassland occupy a small percentage of the farm area",
      "title": "Trwałe użytki zielone zajmują niewielki procent obszaru gospodarstwa",
      "description_en": "Permanent grassland occupy 10% of farm area. It can be used to feed livestock and promote biodiversity.",
      "description": "Trwałe użytki zielone zajmują 10% obszaru gospodarstwa. Mogą być wykorzystywane dla potrzeb żywienia bydła i zwiększenia bioróżnorodności."
    },
    {
      "id": "C.10.3",
      "title_en": "Permanent grassland occupy a high percentage of the farm area",
      "title": "Trwałe użytki zielone zajmują duży procent obszaru gospodarstwa",
      "description_en": "Permanent grassland occupy 20% of farm area. It can be used to feed livestock and promote biodiversity.",
      "description": "Trwałe użytki zielone zajmują 20% obszaru gospodarstwa. Mogą być wykorzystywane dla potrzeb żywienia bydła i zwiększenia bioróżnorodności."
    },
    {
      "id": "C.11.1",
      "title_en": "Sole crops",
      "title": "Pojedyncze uprawy",
      "description_en": "Each crop is grown alone in the field.",
      "description": "Każda roślina jest uprawiana na polu pojedynczo."
    },
    {
      "id": "C.11.2",
      "title_en": "Wheat/pea intercrops",
      "title": "Międzyplony: pszenica/groch",
      "description_en": "Coexistence of the two crops (wheat, pea) on the same field at the same time. Yield of the intercrop will be higher than the average of individual crops on the same area. Intercrops can be valorized as animal feeding. Selling the crops will require additional sorting costs (not considered in the game).",
      "description": "Jednoczesne współistnienie dwóch upraw (pszenica, groch) na tym samym polu. Wydajność międzyplonu będzie wyższa niż średnia dla pojedynczych upraw na tym samym obszarze. Międzyplony można wykorzystywaćjako karmę dla zwierząt. Sprzedaż plonów będzie wymagała dodatkowych kosztów sortowania (nie brane pod uwagę w grze)."
    },
