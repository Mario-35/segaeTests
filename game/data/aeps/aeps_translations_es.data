    {
      "id": "C.15.1",
      "title_en": "No agroforestry",
      "title": "No hay agroforestería.",
      "description_en": "No agroforestry on the farm.",
      "description": "No hay agroforestería en la granja."
    },
    {
      "id": "C.15.2",
      "title_en": "In-field agroforestry",
      "title": "Agroforestería en el campo.",
      "description_en": "A sustainable management system that integrate trees, crops and livestock on the same plot of land. Farm area for crops and temporary grasslands is reduced by 16%.",
      "description": "Un sistema de gestión sostenible que combina árboles, cultivos y ganado en la misma parcela. La superficie agrícola utilizada para cultivos y praderas temporales se reduce en un 16 %."
    },
    {
      "id": "E.1.1",
      "title_en": "Balanced strategy between farmer income and investment",
      "title": "Estrategia equilibrada entre los ingresos del agricultor y las inversiones.",
      "description_en": "Farm profit is equally shared between farmer income and investment capacity.",
      "description": "Las utilidades agrícolas se reparten equitativamente entre los ingresos del agricultor y su capacidad de inversión."
    },
    {
      "id": "E.1.2",
      "title_en": "Investment-oriented strategy",
      "title": "Estrategia orientada a la inversión",
      "description_en": "Farm profit is 80% distributed to investment capacity.",
      "description": "El 80 % de las utilidades agrícolas se dedican a la capacidad de inversión."
    },
    {
      "id": "E.1.3",
      "title_en": "Income-oriented strategy",
      "title": "Estrategia orientada a los ingresos",
      "description_en": "Farm profit is 80% distributed to farmer income.",
      "description": "El 80 % de las utilidades agrícolas se destinan a los ingresos del agricultor."
    },
    {
      "id": "G.1.1",
      "title_en": "Conventional farming",
      "title": "Agricultura convencional",
      "description_en": "It corresponds to the most widespread farm management, with no particular specifications (except the compliance with the Good Agricultural and Environmental conditions of the CAP). Input and output prices are 25% lower than in organic farming.",
      "description": "Corresponde a la gestión agrícola más extendida, sin especificaciones particulares (salvo el cumplimiento de las Buenas condiciones agrícolas y medioambientales de la PAC). Los precios de los insumos y la producción son un 25 % más bajos que los de la agricultura orgánica."
    },
    {
      "id": "G.1.2",
      "title_en": "Organic farming",
      "title": "Agricultura orgánica",
      "description_en": "Specifications of organic farming rely mainly on no chemical input use. Input and output prices are 25% higher in conventional farming.",
      "description": "Las especificaciones de la agricultura orgánica se basan principalmente en la ausencia del uso de productos químicos. Los precios de los insumos y la producción son un 25 % más altos que los de la agricultura orgánica."
    },
    {
      "id": "A.1.1",
      "title_en": "Cattle breed is Holstein",
      "title": "El ganado es de la raza Holstein",
