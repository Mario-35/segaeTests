  "data": [
    {
      "id": "C.1.1",
      "title_en": "Conventional tillage",
      "title": "Labranza convencional (LC)",
      "description_en": "The “traditional” method of farming in which soil is prepared for planting by completely inverting it with a moldboard plow.",
      "description": "Método de cultivo «tradicional» en el que se prepara la tierra para la plantación dándole la vuelta completamente con la ayuda de un arado metálico."
    },
    {
      "id": "C.1.2",
      "title_en": "Reduced tillage",
      "title": "Labranza reducida (LR)",
      "description_en": "Use of only superficial tillage without soil inversion.",
      "description": "Solo labranza superficial, sin volteo."
    },
    {
      "id": "C.1.3",
      "title_en": "No tillage",
      "title": "Cultivo sin labranza (NT)",
      "description_en": "Planting of crops directly (no tillage) in preceding cover crop (living or destroyed, i.e. mulched) or crop residues.",
      "description": "Siembra directa (sin labranza) en el cultivo de cobertura anterior (vivo o destruido, es decir, paja) o en los residuos del cultivo."
    },
    {
      "id": "C.2.1",
      "title_en": "Fall cover crop destructed before winter",
      "title": "Cultivo de cobertura de otoño destruido antes del invierno",
      "description_en": "The cover crop is terminated before winter and the soil is left bare until the spring crop is well established.",
      "description": "El cultivo de cobertura finaliza antes del invierno y el suelo se deja al descubierto hasta que el cultivo de primavera esté bien establecido."
    },
    {
      "id": "C.2.2",
      "title_en": "Fall cover crop destructed early spring",
      "title": "Cultivo de cobertura de otoño destruido a principios de la primavera",
      "description_en": "The fall cover crop is left during winter, covering the soil and is terminated early spring.",
      "description": "El cultivo de cobertura de otoño se deja durante el invierno, cubre el suelo y desaparece a principios de la primavera."
    },
    {
      "id": "C.2.3",
      "title_en": "Permanent soil cover",
      "title": "Cobertura permanente del suelo",
      "description_en": "Implementing this practice means that the soil is never left bare across the whole rotation.",
      "description": "La aplicación de esta práctica implica que el suelo nunca se deja desnudo durante toda la rotación."
    },
    {
      "id": "C.3.1",
      "title_en": "Straw removal",
      "title": "Eliminación de la paja",
      "description_en": "Crop residues are exported from the crop system and used for livestock bedding and/or exported from the farm by selling it.",
      "description": "Se eliminan los residuos del sistema de cultivo y se utilizan para la cama del ganado y/o se sacan de la granja a través de la venta."
    },
    {
      "id": "C.3.2",
      "title_en": "Straw left on soil",
      "title": "Paja que se deja en el suelo",
      "description_en": "Crop residues are left on the soil and are either incorporated into the soil when tilling or are left as mulch when implementing direct seeding.",
      "description": "Los residuos del cultivo se dejan en el suelo y se incorporan a este mediante el arado o se dejan como mantillo cuando no hay labranza."
    },
    {
      "id": "C.4.1",
      "title_en": "On-farm organic fertilizers + input of mineral fertilizer",
      "title": "Fertilizantes orgánicos agrícolas derivados + insumos de fertilizantes minerales",
      "description_en": "The slurry and/or manure produced by animals is used as organic fertilizer and completed by mineral fertiliser.",
      "description": "Los purines y/o el estiércol producidos por los animales se utilizan como fertilizante orgánico y se complementan con un fertilizante mineral."
    },
    {
      "id": "C.4.2",
      "title_en": "On-farm organic fertilizers only",
      "title": "Solo fertilizantes orgánicos de la granja",
      "description_en": "The slurry and/or manure produced by animals is used as organic fertilizer and not complemented.",
      "description": "Los purines y/o el estiércol producidos por los animales se utilizan como fertilizante orgánico y no se complementan."
    },
    {
      "id": "C.5.1",
      "title_en": "Systematic use of chemical fungicides",
      "title": "Uso sistemático de fungicidas químicos",
      "description_en": "Chemical fungicides are systematically used. ",
      "description": "Se utilizan fungicidas químicos sistemáticamente. "
    },
    {
      "id": "C.5.2",
      "title_en": "Sound approach of chemical fungicides",
      "title": "Enfoque racional de los fungicidas químicos",
      "description_en": "The use of chemical fungicides whenever and only if it is absolutely required.",
      "description": "Uso de fungicidas químicos siempre que sea absolutamente necesario."
    },
    {
      "id": "C.5.3",
      "title_en": "Biocontrol products against diseases",
      "title": "Productos de biocontrol contra las enfermedades",
      "description_en": "‘Integrated pest management’ strategy without chemicals.",
      "description": "Estrategia de Manejo integrado de plagas sin productos químicos."
    },
    {
      "id": "C.5.4",
      "title_en": "No direct protection against diseases",
      "title": "No hay protección directa contra las enfermedades",
      "description_en": "No fungicide is applied.",
      "description": "No se utiliza ningún fungicida."
    },
    {
      "id": "C.6.1",
      "title_en": "Systematic and sole use of chemical herbicides",
      "title": "Uso sistemático y único de herbicidas químicos",
      "description_en": "Chemical herbicides are systematically used.",
      "description": "Se utilizan herbicidas químicos sistemáticamente."
    },
    {
      "id": "C.6.2",
      "title_en": "Sound approach of chemical herbicides + mechanical weed control",
      "title": "Enfoque racional de los herbicidas químicos + deshierbe mecánico",
      "description_en": "The use of chemical herbicides whenever and only if it is absolutely required.",
      "description": "Uso de herbicidas químicos siempre y solo si es absolutamente necesario."
    },
    {
      "id": "C.6.3",
      "title_en": "Sole use of mechanical weed control",
      "title": "Uso exclusivo del desmalezado mecánico",
      "description_en": "No herbicide is applied, weed populations are managed through physical methods (e.g. hoeing, harrowing).",
      "description": "No se aplican herbicidas, las malas hierbas se manejan utilizando métodos físicos (por ejemplo, con azadones o gradas)."
    },
    {
      "id": "C.7.1",
      "title_en": "Systematic use of chemical insecticides / molluscicides / nematicides",
      "title": "Uso sistemático de insecticidas molusquicidas/nematicidas químicos",
      "description_en": "Chemical insecticides / molluscicides / nematicides are systematically used to avoid pests, even if the pressure is low.",
      "description": "Los insecticidas/molusquicidas/nematicidas químicos se utilizan de forma rutinaria para evitar las plagas, incluso si la amenaza es baja."
    },
    {
      "id": "C.7.2",
      "title_en": "Sound approach of chemical insecticides / molluscicides / nematicides",
      "title": "Enfoque racional de los insecticidas/molusquicidas/nematicidas químicos",
      "description_en": "Chemical insecticides / molluscicides / nematicides  are applied only if pests are monitored in the field and sprays or other control methods are carried out only when the action threshold is exceeded (Integrated Pest Management).",
      "description": "Los insecticidas/molusquicidas/nematicidas químicos solo se utilizan si se vigilan plagas sobre el terreno y se aplican pulverizaciones u otros métodos de control solo cuando se supera el umbral de acción (manejo integrado de plagas)."
    },
    {
      "id": "C.7.3",
      "title_en": "Biocontrol products (incl. pyrethrin) and other natural control techniques against pests",
      "title": "Productos de biocontrol (incluidas las piretrinas) y otras técnicas naturales de control de plagas",
      "description_en": "Biocontrol products / biopesticides will be applied using a sprayer.",
      "description": "Los productos de biocontrol/biopesticidas se aplicarán mediante un pulverizador."
    },
    {
      "id": "C.7.4",
      "title_en": "No direct protection against animal pests",
      "title": "No hay protección directa contra las plagas",
      "description_en": "No Insecticide / Molluscicide / Nematicide is applied.",
      "description": "No se aplican insecticidas/molusquicidas/nematicidas."
    },
    {
      "id": "C.8.1",
      "title_en": "High yielding cultivars",
      "title": "Variedades de alto rendimiento.",
      "description_en": "Use of one cultivar selected for its high yield in controled conditions.",
      "description": "Utilización de una variedad seleccionada para un alto rendimiento en condiciones controladas."
    },
    {
      "id": "C.8.2",
      "title_en": "Resistant cultivars and/or mix of varieties",
      "title": "Cultivos resistentes y/o mezclas de variedades.",
      "description_en": "Use of one or more cultivars selected for their resistance/tolerance to pests and diseases, but with lower yield in controled conditions.",
      "description": "Utilización de uno o más cultivares seleccionados por su resistencia/tolerancia a las plagas y enfermedades, pero con un rendimiento menor en condiciones controladas."
    },
    {
      "id": "C.9.1",
      "title_en": "Temporary grassland composed of grass",
      "title": "Pradera temporal compuesta de hierba.",
      "description_en": "Land on which the vegetation is dominated by grass such as perennial ryegrass or sheep's fescue.",
      "description": "Tierra donde la vegetación está dominada por la hierba, como la cizaña perenne o la cañuela de oveja."
    },
    {
      "id": "C.9.2",
      "title_en": "Temporary grassland composed of simple grass/legume mixtures",
      "title": "Pradera temporal compuesta de mezclas simples de una hierba y una planta.",
      "description_en": "Land on which the vegetation is dominated by two species, one grass and one legume such as perennial ryegrass and white clover.",
      "description": "Tierra en la que la vegetación está dominada por dos especies, una hierba y otra planta, como la cizaña perenne y el trébol blanco."
    },
    {
      "id": "C.9.3",
      "title_en": "Temporary grassland composed of complex grass/legume mixtures",
      "title": "Pradera temporal compuesta de mezclas complejas de hierbas y plantas.",
      "description_en": "Land on which the vegetation is dominated by various species, grasses, legumes, etc.",
      "description": "Tierra en la que la vegetación está dominada por varias especies, hierbas, plantas, etc."
    },
    {
      "id": "C.10.1",
      "title_en": "No permanent grassland",
      "title": "No hay praderas permanentes",
      "description_en": "No permanent grassland on the farm.",
      "description": "No hay praderas permanentes en la granja."
    },
    {
      "id": "C.10.2",
      "title_en": "Permanent grassland occupy a small percentage of the farm area",
      "title": "Las praderas permanentes ocupan un pequeño porcentaje de la superficie agrícola.",
      "description_en": "Permanent grassland occupy 10% of farm area. It can be used to feed livestock and promote biodiversity.",
      "description": "Las praderas permanentes ocupan el 10 % de la superficie agrícola. Pueden utilizarse para alimentar al ganado y promover la biodiversidad."
    },
    {
      "id": "C.10.3",
      "title_en": "Permanent grassland occupy a high percentage of the farm area",
      "title": "Las praderas permanentes ocupan un gran porcentaje de la superficie agrícola.",
      "description_en": "Permanent grassland occupy 20% of farm area. It can be used to feed livestock and promote biodiversity.",
      "description": "Las praderas permanentes ocupan el 20 % de la superficie agrícola. Pueden utilizarse para alimentar al ganado y promover la biodiversidad."
    },
    {
      "id": "C.11.1",
      "title_en": "Sole crops",
      "title": "Monocultivos",
      "description_en": "Each crop is grown alone in the field.",
      "description": "Solo se desarrolla un cultivo en cada campo."
    },
    {
      "id": "C.11.2",
      "title_en": "Wheat/pea intercrops",
      "title": "Cultivos en asociación de trigo/arvejas.",
      "description_en": "Coexistence of the two crops (wheat, pea) on the same field at the same time. Yield of the intercrop will be higher than the average of individual crops on the same area. Intercrops can be valorized as animal feeding. Selling the crops will require additional sorting costs (not considered in the game).",
      "description": "Coexistencia de los dos cultivos (trigo, arvejas) en el mismo campo al mismo tiempo. El rendimiento del cultivo en asociación será mayor que el promedio de los monocultivos en la misma superficie. Los cultivos en asociación pueden utilizarse para la alimentación de los animales. La venta de las cosechas dará lugar a gastos de clasificación adicionales (no considerados en el juego)."
    },
