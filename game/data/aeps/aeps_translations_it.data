      "title_en": "No particular green infrastructure elements",
      "title": "Nessun elemento di infrastruttura verde particolare",
      "description_en": "No particular green infrastructure elements.",
      "description": "Nessun elemento di infrastruttura verde particolare."
    },
    {
      "id": "C.14.2",
      "title_en": "Sown field margins as green infrastructures: wildflowers strip",
      "title": "Margini dei campi seminati come infrastrutture verdi: striscia di fiori di campo",
      "description_en": "A mix of flowering plants.",
      "description": "Un mix di piante da fiore."
    },
    {
      "id": "C.14.3",
      "title_en": "Sown field margins as green infrastructures: beetle bank (for birds and polyphagous predator)",
      "title": "Margini dei campi seminati come infrastrutture verdi: beetle bank (per uccelli e predatori polifagi)",
      "description_en": "Raised grassy banks, typically 2-3 m wide, sown with tussock forming grasses.",
      "description": "Banchi erbosi rialzati, larghi tipicamente 2-3 m, seminati con graminacee formanti cespi."
