  "data": [
    {
      "id": "C.1.1",
      "title_en": "Conventional tillage",
      "title": "Lavorazione convenzionale",
      "description_en": "The “traditional” method of farming in which soil is prepared for planting by completely inverting it with a moldboard plow.",
      "description": "Il metodo di coltivazione tradizionale in cui il terreno viene preparato per la semina capovolgendolo completamente con un aratro a versoio."
    },
    {
      "id": "C.1.2",
      "title_en": "Reduced tillage",
      "title": "Lavorazione ridotta",
      "description_en": "Use of only superficial tillage without soil inversion.",
      "description": "Utilizzo della sola lavorazione superficiale senza ribaltamento del terreno."
    },
    {
      "id": "C.1.3",
      "title_en": "No tillage",
      "title": "Nessuna lavorazione",
      "description_en": "Planting of crops directly (no tillage) in preceding cover crop (living or destroyed, i.e. mulched) or crop residues.",
      "description": "Piantagione delle colture direttamente (senza lavorazione) in colture di copertura precedenti (vive o distrutte, ossia pacciamate) o residui colturali."
    },
    {
      "id": "C.2.1",
      "title_en": "Fall cover crop destructed before winter",
      "title": "Coltura di copertura autunnale distrutta prima dell'inverno",
      "description_en": "The cover crop is terminated before winter and the soil is left bare until the spring crop is well established.",
      "description": "La coltura di copertura viene interrotta prima dell'inverno e il terreno viene lasciato nudo fino a quando il raccolto primaverile non è ben consolidato."
    },
    {
      "id": "C.2.2",
      "title_en": "Fall cover crop destructed early spring",
      "title": "Coltura di copertura autunnale distrutta all'inizio della primavera",
      "description_en": "The fall cover crop is left during winter, covering the soil and is terminated early spring.",
      "description": "La coltura di copertura autunnale viene lasciata durante l'inverno, coprendo il terreno e viene interrotta all'inizio della primavera."
    },
    {
      "id": "C.2.3",
      "title_en": "Permanent soil cover",
      "title": "Copertura permanente del terreno",
      "description_en": "Implementing this practice means that the soil is never left bare across the whole rotation.",
      "description": "L'implementazione di questa pratica significa che il terreno non viene mai lasciato nudo durante l'intera rotazione."
    },
    {
      "id": "C.3.1",
      "title_en": "Straw removal",
      "title": "Rimozione della paglia",
      "description_en": "Crop residues are exported from the crop system and used for livestock bedding and/or exported from the farm by selling it.",
      "description": "I residui colturali vengono esportati dal sistema colturale e utilizzati per la lettiera del bestiame e/o esportati dall'azienda attraverso la vendita."
    },
    {
      "id": "C.3.2",
      "title_en": "Straw left on soil",
      "title": "Paglia lasciata sul terreno",
      "description_en": "Crop residues are left on the soil and are either incorporated into the soil when tilling or are left as mulch when implementing direct seeding.",
      "description": "I residui colturali vengono lasciati sul terreno e vengono incorporati nel suolo durante la lavorazione o vengono lasciati come pacciame quando si effettua la semina diretta."
    },
    {
      "id": "C.4.1",
      "title_en": "On-farm organic fertilizers + input of mineral fertilizer",
      "title": "Fertilizzanti organici in azienda + apporto di fertilizzanti minerali",
      "description_en": "The slurry and/or manure produced by animals is used as organic fertilizer and completed by mineral fertiliser.",
      "description": "Il liquame e/o il letame prodotto dagli animali viene utilizzato come fertilizzante organico e integrato con fertilizzante minerale."
    },
    {
      "id": "C.4.2",
      "title_en": "On-farm organic fertilizers only",
      "title": "Solo fertilizzanti organici in azienda",
      "description_en": "The slurry and/or manure produced by animals is used as organic fertilizer and not complemented.",
      "description": "Il liquame e/o il letame prodotto dagli animali viene utilizzato come fertilizzante organico e non viene integrato."
    },
    {
      "id": "C.5.1",
      "title_en": "Systematic use of chemical fungicides",
      "title": "Uso sistematico di fungicidi chimici",
      "description_en": "Chemical fungicides are systematically used. ",
      "description": "I fungicidi chimici vengono utilizzati sistematicamente."
    },
    {
      "id": "C.5.2",
      "title_en": "Sound approach of chemical fungicides",
      "title": "Approccio sano all'uso di fungicidi chimici",
      "description_en": "The use of chemical fungicides whenever and only if it is absolutely required.",
      "description": "L'uso di fungicidi chimici avviene quando e solo se è assolutamente necessario."
    },
    {
      "id": "C.5.3",
      "title_en": "Biocontrol products against diseases",
      "title": "Prodotti di biocontrollo contro le malattie",
      "description_en": "‘Integrated pest management’ strategy without chemicals.",
      "description": "Strategia di gestione integrata dei parassiti senza prodotti chimici."
    },
    {
      "id": "C.5.4",
      "title_en": "No direct protection against diseases",
      "title": "Nessuna protezione diretta contro le malattie",
      "description_en": "No fungicide is applied.",
      "description": "Non viene applicato alcun fungicida."
    },
    {
      "id": "C.6.1",
      "title_en": "Systematic and sole use of chemical herbicides",
      "title": "Uso sistematico e esclusivo di erbicidi chimici",
      "description_en": "Chemical herbicides are systematically used.",
      "description": "Gli erbicidi chimici vengono utilizzati sistematicamente."
    },
    {
      "id": "C.6.2",
      "title_en": "Sound approach of chemical herbicides + mechanical weed control",
      "title": "Approccio sano all'uso di erbicidi chimici + controllo meccanico delle infestanti",
      "description_en": "The use of chemical herbicides whenever and only if it is absolutely required.",
      "description": "L'uso di erbicidi chimici avviene quando e solo se è assolutamente necessario."
    },
    {
      "id": "C.6.3",
      "title_en": "Sole use of mechanical weed control",
      "title": "Uso esclusivo del controllo meccanico delle infestanti",
      "description_en": "No herbicide is applied, weed populations are managed through physical methods (e.g. hoeing, harrowing).",
      "description": "Non viene applicato alcun erbicida, le popolazioni di infestanti vengono gestite attraverso metodi fisici (es. zappatura, erpicatura)."
    },
    {
      "id": "C.7.1",
      "title_en": "Systematic use of chemical insecticides / molluscicides / nematicides",
      "title": "Uso sistematico di insetticidi / molluschicidi /nematocidi chimici",
      "description_en": "Chemical insecticides / molluscicides / nematicides are systematically used to avoid pests, even if the pressure is low.",
      "description": "Insetticidi /molluschicidi /nematocidi chimici vengo utilizzati sistematicamente per prevenire i parassiti, anche se la pressione è bassa."
    },
    {
      "id": "C.7.2",
      "title_en": "Sound approach of chemical insecticides / molluscicides / nematicides",
      "title": "Approccio sano all'uso di insetticidi / molluschicidi / nematocidi chimici",
      "description_en": "Chemical insecticides / molluscicides / nematicides  are applied only if pests are monitored in the field and sprays or other control methods are carried out only when the action threshold is exceeded (Integrated Pest Management).",
      "description": "Gli insetticidi / molluschicidi / nematocidi chimici vengono applicati solo se i parassiti sono monitorati sul campo e irrorazioni o altri metodi di controllo vengono eseguiti solo quando la soglia di intervento viene superata (Gestione Integrata dei Parassiti)."
    },
    {
      "id": "C.7.3",
      "title_en": "Biocontrol products (incl. pyrethrin) and other natural control techniques against pests",
      "title": "Prodotti di biocontrollo (incl. piretrina) e altre tecniche naturali di controllo contro i parassiti",
      "description_en": "Biocontrol products / biopesticides will be applied using a sprayer.",
      "description": "I prodotti di biocontrollo / biopesticidi verranno applicati utilizzando uno spruzzatore."
    },
    {
      "id": "C.7.4",
      "title_en": "No direct protection against animal pests",
      "title": "Nessuna protezione diretta contro i parassiti degli animali",
      "description_en": "No Insecticide / Molluscicide / Nematicide is applied.",
      "description": "Non viene applicato alcun insetticida / molluschicida / nematocida."
    },
    {
      "id": "C.8.1",
      "title_en": "High yielding cultivars",
      "title": "Cultivar ad alto rendimento",
      "description_en": "Use of one cultivar selected for its high yield in controled conditions.",
      "description": "Utilizzo di una cultivar selezionata per la sua elevata resa in condizioni controllate."
    },
    {
      "id": "C.8.2",
      "title_en": "Resistant cultivars and/or mix of varieties",
      "title": "Cultivar resistenti e/o mix di varietà",
      "description_en": "Use of one or more cultivars selected for their resistance/tolerance to pests and diseases, but with lower yield in controled conditions.",
      "description": "Utilizzo di una o più cultivar selezionate per la loro resistenza/tolleranza a parassiti e malattie, ma con resa inferiore in condizioni controllate."
    },
    {
      "id": "C.9.1",
      "title_en": "Temporary grassland composed of grass",
      "title": "Prati temporanei costituiti da erba",
      "description_en": "Land on which the vegetation is dominated by grass such as perennial ryegrass or sheep's fescue.",
      "description": "Terreno in cui la vegetazione è dominata da graminacee come loietto perenne o festuca ovina."
    },
    {
      "id": "C.9.2",
      "title_en": "Temporary grassland composed of simple grass/legume mixtures",
      "title": "Prati temporanei costituiti da miscele semplici di graminacee/legumi",
      "description_en": "Land on which the vegetation is dominated by two species, one grass and one legume such as perennial ryegrass and white clover.",
      "description": "Terreno in cui la vegetazione è dominata da due specie, una graminacea e una leguminosa come loietto perenne e trifoglio bianco."
    },
    {
      "id": "C.9.3",
      "title_en": "Temporary grassland composed of complex grass/legume mixtures",
      "title": "Prati temporanei costituiti da miscele complesse di graminacee/legumi",
      "description_en": "Land on which the vegetation is dominated by various species, grasses, legumes, etc.",
      "description": "Terreno in cui la vegetazione è dominata da varie specie, graminacee, leguminose, ecc."
    },
    {
      "id": "C.10.1",
      "title_en": "No permanent grassland",
      "title": "Nessun prato permanente",
      "description_en": "No permanent grassland on the farm.",
      "description": "Nessun prato permanente nell'azienda."
    },
    {
      "id": "C.10.2",
      "title_en": "Permanent grassland occupy a small percentage of the farm area",
      "title": "Il prato permanente occupa una piccola percentuale della superficie agricola",
      "description_en": "Permanent grassland occupy 10% of farm area. It can be used to feed livestock and promote biodiversity.",
      "description": "Il prato permanente occupa il 10% della superficie agricola. Può essere utilizzato per nutrire il bestiame e favorire la biodiversità."
    },
    {
      "id": "C.10.3",
      "title_en": "Permanent grassland occupy a high percentage of the farm area",
      "title": "Il prato permanente occupa un'alta percentuale della superficie agricola",
      "description_en": "Permanent grassland occupy 20% of farm area. It can be used to feed livestock and promote biodiversity.",
      "description": "Il prato permanente occupa il 20% della superficie agricola. Può essere utilizzato per nutrire il bestiame e favorire la biodiversità."
    },
    {
      "id": "C.11.1",
      "title_en": "Sole crops",
      "title": "Monocolture",
      "description_en": "Each crop is grown alone in the field.",
      "description": "Ogni coltura viene coltivata da sola nel campo."
    },
    {
      "id": "C.11.2",
      "title_en": "Wheat/pea intercrops",
      "title": "Colture consociate di grano/pisello",
      "description_en": "Coexistence of the two crops (wheat, pea) on the same field at the same time. Yield of the intercrop will be higher than the average of individual crops on the same area. Intercrops can be valorized as animal feeding. Selling the crops will require additional sorting costs (not considered in the game).",
      "description": "Coesistenza delle due colture (grano, pisello) sullo stesso campo contemporaneamente. La resa dell'intercoltura sarà superiore alla media delle singole colture sulla stessa area. Le colture consociate possono essere valorizzate come mangime animale. La vendita dei raccolti richiederà costi di cernita aggiuntivi (non considerati nel gioco)."
    },
