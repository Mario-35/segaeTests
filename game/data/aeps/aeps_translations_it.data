    {
      "id": "C.15.1",
      "title_en": "No agroforestry",
      "title": "Nessuna agroforestazione",
      "description_en": "No agroforestry on the farm.",
      "description": "Nessuna agroforestazione in azienda."
    },
    {
      "id": "C.15.2",
      "title_en": "In-field agroforestry",
      "title": "Agroforestazione in campo",
      "description_en": "A sustainable management system that integrate trees, crops and livestock on the same plot of land. Farm area for crops and temporary grasslands is reduced by 16%.",
      "description": "Un sistema di gestione sostenibile che integra alberi, colture e bestiame sullo stesso appezzamento di terreno. La superficie agricola per colture e prati temporanei è ridotta del 16%."
    },
    {
      "id": "E.1.1",
      "title_en": "Balanced strategy between farmer income and investment",
      "title": "Strategia equilibrata tra reddito dell'agricoltore e investimento",
      "description_en": "Farm profit is equally shared between farmer income and investment capacity.",
      "description": "Il profitto dell'azienda agricola è equamente ripartito tra reddito dell'agricoltore e capacità di investimento."
    },
    {
      "id": "E.1.2",
      "title_en": "Investment-oriented strategy",
      "title": "Strategia orientata agli investimenti",
      "description_en": "Farm profit is 80% distributed to investment capacity.",
      "description": "Il profitto dell'azienda agricola viene distribuito all'80% alla capacità di investimento."
    },
    {
      "id": "E.1.3",
      "title_en": "Income-oriented strategy",
      "title": "Strategia orientata al reddito",
      "description_en": "Farm profit is 80% distributed to farmer income.",
      "description": "Il profitto dell'azienda agricola viene distribuito all'80% sul reddito dell'agricoltore."
    },
    {
      "id": "G.1.1",
      "title_en": "Conventional farming",
      "title": "Agricoltura convenzionale",
      "description_en": "It corresponds to the most widespread farm management, with no particular specifications (except the compliance with the Good Agricultural and Environmental conditions of the CAP). Input and output prices are 25% lower than in organic farming.",
      "description": "Corrisponde alla gestione aziendale più diffusa, priva di specifiche particolari (eccezion fatta per il rispetto delle Buone Condizioni Agronomiche e Ambientali della PAC). I prezzi di input e output sono inferiori del 25% rispetto all'agricoltura biologica."
    },
    {
      "id": "G.1.2",
      "title_en": "Organic farming",
      "title": "Agricoltura biologica",
      "description_en": "Specifications of organic farming rely mainly on no chemical input use. Input and output prices are 25% higher in conventional farming.",
      "description": "Le specifiche dell'agricoltura biologica si basano principalmente sul non utilizzo di sostanze chimiche. I prezzi di input e output sono più alti del 25% rispetto all'agricoltura convenzionale."
    },
    {
      "id": "A.1.1",
      "title_en": "Cattle breed is Holstein",
      "title": "La razza bovina è Frisona",
