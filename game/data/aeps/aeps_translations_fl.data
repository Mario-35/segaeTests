    {
      "id": "C.15.1",
      "title_en": "No agroforestry",
      "title": "Geen boslandbouw",
      "description_en": "No agroforestry on the farm.",
      "description": "Geen boslandbouw op de boerderij."
    },
    {
      "id": "C.15.2",
      "title_en": "In-field agroforestry",
      "title": "Boslandbouw in het veld",
      "description_en": "A sustainable management system that integrate trees, crops and livestock on the same plot of land. Farm area for crops and temporary grasslands is reduced by 16%.",
      "description": "Een duurzaam beheerssysteem dat bomen, gewassen en vee integreert op hetzelfde perceel. Het boerderijgebied voor gewassen en tijdelijke graslanden wordt met 16% gereduceerd."
    },
    {
      "id": "E.1.1",
      "title_en": "Balanced strategy between farmer income and investment",
      "title": "Gebalanceerde strategie tussen inkomsten voor de boer en investeringen",
      "description_en": "Farm profit is equally shared between farmer income and investment capacity.",
      "description": "De winst voor de boerderij wordt gelijk verdeeld over het inkomen van de boer en de investeringscapaciteit."
    },
    {
      "id": "E.1.2",
      "title_en": "Investment-oriented strategy",
      "title": "Investeringsgerichte strategie",
      "description_en": "Farm profit is 80% distributed to investment capacity.",
      "description": "De opbrengst van de boerderij wordt voor 80% besteed aan investeringen."
    },
    {
      "id": "E.1.3",
      "title_en": "Income-oriented strategy",
      "title": "Inkomensgerichte strategie",
      "description_en": "Farm profit is 80% distributed to farmer income.",
      "description": "De opbrengst van de boerderij wordt voor 80% besteed aan het inkomen van de boer."
    },
    {
      "id": "G.1.1",
      "title_en": "Conventional farming",
      "title": "Conventionele landbouw",
      "description_en": "It corresponds to the most widespread farm management, with no particular specifications (except the compliance with the Good Agricultural and Environmental conditions of the CAP). Input and output prices are 25% lower than in organic farming.",
      "description": "Dit is het meest voorkomende landbouwbeheer, zonder duidelijke specificatie (behalve naleving van Goede Landbouw- en Milieuomstandigheden van het CAP). De input- en outputprijzen liggen 25% lager dan bij organische landbouw."
    },
    {
      "id": "G.1.2",
      "title_en": "Organic farming",
      "title": "Organische landbouw",
      "description_en": "Specifications of organic farming rely mainly on no chemical input use. Input and output prices are 25% higher in conventional farming.",
      "description": "De kenmerken van organische landbouw komen hoofdzakelijk neer op het niet-gebruiken van chemische input. De input- en outputprijzen liggen 25% hoger dan bij conventionele landbouw."
    },
    {
      "id": "A.1.1",
      "title_en": "Cattle breed is Holstein",
      "title": "Het runderras is Holstein",
      "description_en": "Holstein is a breed of dairy cattle used for high milk production.",
      "description": "Holstein is een melkveeras dat wordt gebruikt voor een hoge melkproductie."
    },
    {
      "id": "A.1.2",
