    {
      "id": "C.14.1",
      "title_en": "No particular green infrastructure elements",
      "title": "Geen specifieke groene onderdelen van de infrastructuur",
      "description_en": "No particular green infrastructure elements.",
      "description": "Geen specifieke groene onderdelen van de infrastructuur."
    },
    {
      "id": "C.14.2",
      "title_en": "Sown field margins as green infrastructures: wildflowers strip",
      "title": "Ingezaaide veldmarges als groene infrastructuren: strook veldbloemen",
      "description_en": "A mix of flowering plants.",
      "description": "Een mix van bloeiende planten."
    },
    {
      "id": "C.14.3",
      "title_en": "Sown field margins as green infrastructures: beetle bank (for birds and polyphagous predator)",
      "title": "Ingezaaide veldmarges als groene infrastructuren: keverbank (voor vogels en polyfage roofdieren)",
