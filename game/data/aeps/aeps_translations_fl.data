  "data": [
    {
      "id": "C.1.1",
      "title_en": "Conventional tillage",
      "title": "Conventionele grondbewerking",
      "description_en": "The “traditional” method of farming in which soil is prepared for planting by completely inverting it with a moldboard plow.",
      "description": "De \"traditionele\" landbouwmethode waarbij grond voor beplanting wordt voorbereid door deze volledig om te ploegen met een molbordploeg."
    },
    {
      "id": "C.1.2",
      "title_en": "Reduced tillage",
      "title": "Gereduceerde grondbewerking",
      "description_en": "Use of only superficial tillage without soil inversion.",
      "description": "Uitsluitend gebruik van oppervlaktegrondbewerking zonder kering van de grond."
    },
    {
      "id": "C.1.3",
      "title_en": "No tillage",
      "title": "Geen grondbewerking",
      "description_en": "Planting of crops directly (no tillage) in preceding cover crop (living or destroyed, i.e. mulched) or crop residues.",
      "description": "Het direct planten van gewassen (zonder grondbewerking) op bodembegroeiing (levend of verwoest, bijv. aangeaard) of gewasresten."
    },
    {
      "id": "C.2.1",
      "title_en": "Fall cover crop destructed before winter",
      "title": "Herfstbegroeiing vernietigd voor de winter",
      "description_en": "The cover crop is terminated before winter and the soil is left bare until the spring crop is well established.",
      "description": "De bodembegroeiing wordt voor de winter beëindigd en de grond wordt onbegroeid gelaten totdat de voorjaarsteelt zich goed gevestigd heeft."
    },
    {
      "id": "C.2.2",
      "title_en": "Fall cover crop destructed early spring",
      "title": "Herfstbegroeiing vernietigd in de vroege lente",
      "description_en": "The fall cover crop is left during winter, covering the soil and is terminated early spring.",
      "description": "De herfstbegroeiing wordt gedurende de winter met rust gelaten en in de vroege lente beëindigd."
    },
    {
      "id": "C.2.3",
      "title_en": "Permanent soil cover",
      "title": "Permanente grondbedekking",
      "description_en": "Implementing this practice means that the soil is never left bare across the whole rotation.",
      "description": "Deze praktijk houdt in dat de grond nooit onbegroeid is gedurende de hele rotatiecyclus."
    },
    {
      "id": "C.3.1",
      "title_en": "Straw removal",
      "title": "Stroverwijdering",
      "description_en": "Crop residues are exported from the crop system and used for livestock bedding and/or exported from the farm by selling it.",
      "description": "Gewasresten worden uit het gewassysteem geëxporteerd en gebruikt als strooisel voor stallen en/of verkocht."
    },
    {
      "id": "C.3.2",
      "title_en": "Straw left on soil",
      "title": "Stro achtergelaten op de grond",
      "description_en": "Crop residues are left on the soil and are either incorporated into the soil when tilling or are left as mulch when implementing direct seeding.",
      "description": "Gewasresten worden op de grond achtergelaten en ingecorporeerd in de grond tijdens grondbewerking of achtergelaten als mulch tijdens direct zaaien."
    },
    {
      "id": "C.4.1",
      "title_en": "On-farm organic fertilizers + input of mineral fertilizer",
      "title": "Organische mest + invoer van minerale mest op landbouwbedrijven",
      "description_en": "The slurry and/or manure produced by animals is used as organic fertilizer and completed by mineral fertiliser.",
      "description": "Door dieren geproduceerde gier en/of mest wordt gebruikt als organische mest en aangevuld met minerale mest."
    },
    {
      "id": "C.4.2",
      "title_en": "On-farm organic fertilizers only",
      "title": "Uitsluitend organische mest op landbouwbedrijven",
      "description_en": "The slurry and/or manure produced by animals is used as organic fertilizer and not complemented.",
      "description": "Door dieren geproduceerde gier en/of mest wordt gebruikt als organische mest en niet aangevuld."
    },
    {
      "id": "C.5.1",
      "title_en": "Systematic use of chemical fungicides",
      "title": "Systematisch gebruik van chemische fungiciden",
      "description_en": "Chemical fungicides are systematically used. ",
      "description": "Chemische fungiciden worden systematisch gebruikt. "
    },
    {
      "id": "C.5.2",
      "title_en": "Sound approach of chemical fungicides",
      "title": "Gezonde benadering van chemische fungiciden",
      "description_en": "The use of chemical fungicides whenever and only if it is absolutely required.",
      "description": "Gebruik van chemische fungiciden alleen wanneer absoluut vereist."
    },
    {
      "id": "C.5.3",
      "title_en": "Biocontrol products against diseases",
      "title": "Biocontroleproducten tegen ziektes",
      "description_en": "‘Integrated pest management’ strategy without chemicals.",
      "description": "Geïntegreerde plaagbestrijdingsstrategieën zonder chemicaliën."
    },
    {
      "id": "C.5.4",
      "title_en": "No direct protection against diseases",
      "title": "Geen directe bescherming tegen ziektes",
      "description_en": "No fungicide is applied.",
      "description": "Geen toepassing van fungiciden."
    },
    {
      "id": "C.6.1",
      "title_en": "Systematic and sole use of chemical herbicides",
      "title": "Systematisch en uitsluitend gebruik van chemische herbiciden",
      "description_en": "Chemical herbicides are systematically used.",
      "description": "Chemische herbiciden worden systematisch gebruikt."
    },
    {
      "id": "C.6.2",
      "title_en": "Sound approach of chemical herbicides + mechanical weed control",
      "title": "Gezonde benadering van chemische herbiciden + mechanische onkruidbestrijding",
      "description_en": "The use of chemical herbicides whenever and only if it is absolutely required.",
      "description": "Gebruik van chemische herbiciden alleen wanneer absoluut vereist."
    },
    {
      "id": "C.6.3",
      "title_en": "Sole use of mechanical weed control",
      "title": "Uitsluitend gebruik van mechanische onkruidbestrijding",
      "description_en": "No herbicide is applied, weed populations are managed through physical methods (e.g. hoeing, harrowing).",
      "description": "Er worden geen herbiciden toegepast maar onkruid wordt bestreden d.m.v. fysieke methoden (bijv. door schoffelen en eggen)."
    },
    {
      "id": "C.7.1",
      "title_en": "Systematic use of chemical insecticides / molluscicides / nematicides",
      "title": "Systematisch gebruik van chemische insecticiden/mollusciciden/nematiciden",
      "description_en": "Chemical insecticides / molluscicides / nematicides are systematically used to avoid pests, even if the pressure is low.",
      "description": "Chemische insecticiden/mollusciciden/nematiciden worden systematisch gebruikt ter preventie van plagen, zelfs bij lage druk."
    },
    {
      "id": "C.7.2",
      "title_en": "Sound approach of chemical insecticides / molluscicides / nematicides",
      "title": "Gezonde benadering van chemische insecticiden/mollusciciden/nematiciden",
      "description_en": "Chemical insecticides / molluscicides / nematicides  are applied only if pests are monitored in the field and sprays or other control methods are carried out only when the action threshold is exceeded (Integrated Pest Management).",
      "description": "Chemische insecticiden/mollusciciden/nematiciden worden alleen toegepast als de plagen in het veld worden gemonitord, en bespuiting of andere bestrijdingsmethoden worden alleen toegepast wanneer de actiedrempel wordt overschreden (Geïntegreerde Plaagbestrijding)."
    },
    {
      "id": "C.7.3",
      "title_en": "Biocontrol products (incl. pyrethrin) and other natural control techniques against pests",
      "title": "Biocontroleproducten (bijv. pyrethrine) en andere natuurlijke plaagbestrijdingstechnieken",
      "description_en": "Biocontrol products / biopesticides will be applied using a sprayer.",
      "description": "Biocontroleproducten/biopesticiden worden toegepast met een sproeier."
    },
    {
      "id": "C.7.4",
      "title_en": "No direct protection against animal pests",
      "title": "Geen directe bescherming tegen dierlijke plagen",
      "description_en": "No Insecticide / Molluscicide / Nematicide is applied.",
      "description": "Geen insecticide/molluscicide/nematicide toegepast."
    },
    {
      "id": "C.8.1",
      "title_en": "High yielding cultivars",
      "title": "Cultivars voor grote oogst",
      "description_en": "Use of one cultivar selected for its high yield in controled conditions.",
      "description": "Gebruik van een cultivar die wordt gekozen om de grote oogst onder gecontroleerde omstandigheden."
    },
    {
      "id": "C.8.2",
      "title_en": "Resistant cultivars and/or mix of varieties",
      "title": "Bestendige cultivars en/of een mix van verschillende soorten",
      "description_en": "Use of one or more cultivars selected for their resistance/tolerance to pests and diseases, but with lower yield in controled conditions.",
      "description": "Gebruik van een of meerdere cultivars die zijn geselecteerd om hun weerstand/tolerantie voor plagen en ziekten, maar met lagere oogst, onder gecontroleerde omstandigheden."
    },
    {
      "id": "C.9.1",
      "title_en": "Temporary grassland composed of grass",
      "title": "Tijdelijk grasland samengesteld uit gras",
      "description_en": "Land on which the vegetation is dominated by grass such as perennial ryegrass or sheep's fescue.",
      "description": "Land waarop de begroeiing wordt gedomineerd door gras als meerjarig raaigras of schapengras."
    },
    {
      "id": "C.9.2",
      "title_en": "Temporary grassland composed of simple grass/legume mixtures",
      "title": "Tijdelijk grasland bestaand uit eenvoudige gras-/leguminosemengsels",
      "description_en": "Land on which the vegetation is dominated by two species, one grass and one legume such as perennial ryegrass and white clover.",
      "description": "Land waarop de begroeiing wordt gedomineerd door twee soorten; een gras- en een leguminosesoort zoals meerjarig raaigras en witte klaver."
    },
    {
      "id": "C.9.3",
      "title_en": "Temporary grassland composed of complex grass/legume mixtures",
      "title": "Tijdelijk grasland bestaand uit complexe gras-/leguminosemengsels",
      "description_en": "Land on which the vegetation is dominated by various species, grasses, legumes, etc.",
      "description": "Land waarop de begroeiing wordt gedomineerd door verschillende soorten, grassen, leguminosen etc."
    },
    {
      "id": "C.10.1",
      "title_en": "No permanent grassland",
      "title": "Geen permanent grasland",
      "description_en": "No permanent grassland on the farm.",
      "description": "Geen permanent grasland op de boerderij."
    },
    {
      "id": "C.10.2",
      "title_en": "Permanent grassland occupy a small percentage of the farm area",
      "title": "Permanent grasland vormt een klein percentage van het landbouwgebied",
      "description_en": "Permanent grassland occupy 10% of farm area. It can be used to feed livestock and promote biodiversity.",
      "description": "Permanent grasland vormt 10% van het landbouwgebied Het kan worden gebruikt om vee mee te voeden en de biodiversiteit te bevorderen."
    },
    {
      "id": "C.10.3",
      "title_en": "Permanent grassland occupy a high percentage of the farm area",
      "title": "Permanent grasland vormt een groot percentage van het landbouwgebied",
      "description_en": "Permanent grassland occupy 20% of farm area. It can be used to feed livestock and promote biodiversity.",
      "description": "Permanent grasland vormt 20% van het landbouwgebied Het kan worden gebruikt om vee mee te voeden en de biodiversiteit te bevorderen."
    },
    {
      "id": "C.11.1",
      "title_en": "Sole crops",
      "title": "Losse gewassen",
      "description_en": "Each crop is grown alone in the field.",
      "description": "Ieder gewas groeit alleen in het veld."
    },
    {
      "id": "C.11.2",
      "title_en": "Wheat/pea intercrops",
      "title": "Tussengewassen van tarwe/erwt ",
      "description_en": "Coexistence of the two crops (wheat, pea) on the same field at the same time. Yield of the intercrop will be higher than the average of individual crops on the same area. Intercrops can be valorized as animal feeding. Selling the crops will require additional sorting costs (not considered in the game).",
      "description": "Gezamenlijk bestaan van twee gewassen (tarwe/erwt) tegelijk op hetzelfde veld. De oogst van het tussengewas zal groter zijn dan het gemiddelde van de individuele gewassen op hetzelfde gebied. Tussengewassen kunnen worden gevaloriseerd als dierenvoer. Verkoop van de gewassen brengt aanvullende sorteerkosten met zich mee (niet in beschouwing genomen in het spel)."
    },
