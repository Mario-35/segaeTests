  "data": [
    {
      "id": "C.1.1",
      "title": "Conventional tillage",
      "category": "tillage_management",
      "active_at_start": true,
      "description": "The “traditional” method of farming in which soil is prepared for planting by completely inverting it with a moldboard plow."
    },
    {
      "id": "C.1.2",
      "title": "Reduced tillage",
      "category": "tillage_management",
      "active_at_start": false,
      "description": "Use of only superficial tillage without soil inversion."
    },
    {
      "id": "C.1.3",
      "title": "No tillage",
      "category": "tillage_management",
      "active_at_start": false,
      "description": "Planting of crops directly (no tillage) in preceding cover crop (living or destroyed, i.e. mulched) or crop residues."
    },
    {
      "id": "C.2.1",
      "title": "Fall cover crop destructed before winter",
      "category": "soil_cover",
      "active_at_start": false,
      "description": "The cover crop is terminated before winter and the soil is left bare until the spring crop is well established."
    },
    {
      "id": "C.2.2",
      "title": "Fall cover crop destructed early spring",
      "category": "soil_cover",
      "active_at_start": true,
      "description": "The fall cover crop is left during winter, covering the soil and is terminated early spring."
    },
    {
      "id": "C.2.3",
      "title": "Permanent soil cover",
      "category": "soil_cover",
      "active_at_start": false,
      "description": "Implementing this practice means that the soil is never left bare across the whole rotation."
    },
    {
      "id": "C.3.1",
      "title": "Straw removal",
      "category": "residues_management",
      "active_at_start": true,
      "description": "Crop residues are exported from the crop system and used for livestock bedding and/or exported from the farm by selling it."
    },
    {
      "id": "C.3.2",
      "title": "Straw left on soil",
      "category": "residues_management",
      "active_at_start": false,
      "description": "Crop residues are left on the soil and are either incorporated into the soil when tilling or are left as mulch when implementing direct seeding."
    },
    {
      "id": "C.4.1",
      "title": "On-farm organic fertilizers + input of mineral fertilizer",
      "category": "fertilisation",
      "active_at_start": true,
      "description": "The slurry and/or manure produced by animals is used as organic fertilizer and completed by mineral fertiliser."
    },
    {
      "id": "C.4.2",
      "title": "On-farm organic fertilizers only",
      "category": "fertilisation",
      "active_at_start": false,
      "description": "The slurry and/or manure produced by animals is used as organic fertilizer and not complemented."
    },
    {
      "id": "C.5.1",
      "title": "Systematic use of chemical fungicides",
      "category": "crop_protection_against_diseases",
      "active_at_start": true,
      "description": "Chemical fungicides are systematically used. "
    },
    {
      "id": "C.5.2",
      "title": "Sound approach of chemical fungicides",
      "category": "crop_protection_against_diseases",
      "active_at_start": false,
      "description": "The use of chemical fungicides whenever and only if it is absolutely required."
    },
    {
      "id": "C.5.3",
      "title": "Biocontrol products against diseases",
      "category": "crop_protection_against_diseases",
      "active_at_start": false,
      "description": "‘Integrated pest management’ strategy without chemicals."
    },
    {
      "id": "C.5.4",
      "title": "No direct protection against diseases",
      "category": "crop_protection_against_diseases",
      "active_at_start": false,
      "description": "No fungicide is applied."
    },
    {
      "id": "C.6.1",
      "title": "Systematic and sole use of chemical herbicides",
      "category": "weed_control",
      "active_at_start": true,
      "description": "Chemical herbicides are systematically used."
    },
    {
      "id": "C.6.2",
      "title": "Sound approach of chemical herbicides + mechanical weed control",
      "category": "weed_control",
      "active_at_start": false,
      "description": "The use of chemical herbicides whenever and only if it is absolutely required."
    },
    {
      "id": "C.6.3",
      "title": "Sole use of mechanical weed control",
      "category": "weed_control",
      "active_at_start": false,
      "description": "No herbicide is applied, weed populations are managed through physical methods (e.g. hoeing, harrowing)."
    },
    {
      "id": "C.7.1",
      "title": "Systematic use of chemical insecticides / molluscicides / nematicides",
      "category": "crop_protection_against_animal_pests",
      "active_at_start": true,
      "description": "Chemical insecticides / molluscicides / nematicides are systematically used to avoid pests, even if the pressure is low."
    },
    {
      "id": "C.7.2",
      "title": "Sound approach of chemical insecticides / molluscicides / nematicides",
      "category": "crop_protection_against_animal_pests",
      "active_at_start": false,
      "description": "Chemical insecticides / molluscicides / nematicides  are applied only if pests are monitored in the field and sprays or other control methods are carried out only when the action threshold is exceeded (Integrated Pest Management)."
    },
    {
      "id": "C.7.3",
      "title": "Biocontrol products (incl. pyrethrin) and other natural control techniques against pests",
      "category": "crop_protection_against_animal_pests",
      "active_at_start": false,
      "description": "Biocontrol products / biopesticides will be applied using a sprayer."
    },
    {
      "id": "C.7.4",
      "title": "No direct protection against animal pests",
      "category": "crop_protection_against_animal_pests",
      "active_at_start": false,
      "description": "No Insecticide / Molluscicide / Nematicide is applied."
    },
    {
      "id": "C.8.1",
      "title": "High yielding cultivars",
      "category": "cash_crop_cultivars",
      "active_at_start": true,
      "description": "Use of one cultivar selected for its high yield in controled conditions."
    },
    {
      "id": "C.8.2",
      "title": "Resistant cultivars and/or mix of varieties",
      "category": "cash_crop_cultivars",
      "active_at_start": false,
      "description": "Use of one or more cultivars selected for their resistance/tolerance to pests and diseases, but with lower yield in controled conditions."
    },
    {
