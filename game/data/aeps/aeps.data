    },
    {
      "id": "C.11.1",
      "title": "Sole crops",
      "category": "spatial_distribution_of_cash_crops",
      "active_at_start": true,
      "description": "Each crop is grown alone in the field."
    },
    {
      "id": "C.11.2",
      "title": "Wheat/pea intercrops",
      "category": "spatial_distribution_of_cash_crops",
      "active_at_start": false,
      "description": "Coexistence of the two crops (wheat, pea) on the same field at the same time. Yield of the intercrop will be higher than the average of individual crops on the same area. Intercrops can be valorized as animal feeding. Selling the crops will require additional sorting costs (not considered in the game)."
    },
