    },
    {
      "id": "C.10.1",
      "title": "No permanent grassland",
      "category": "permanent_grassland_area",
      "active_at_start": false,
      "description": "No permanent grassland on the farm."
    },
    {
      "id": "C.10.2",
      "title": "Permanent grassland occupy a small percentage of the farm area",
      "category": "permanent_grassland_area",
