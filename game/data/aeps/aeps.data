    {
      "id": "G.1.1",
      "title": "Conventional farming",
      "category": "type_of_agriculture",
      "active_at_start": true,
      "description": "It corresponds to the most widespread farm management, with no particular specifications (except the compliance with the Good Agricultural and Environmental conditions of the CAP). Input and output prices are 25% lower than in organic farming."
    },
    {
      "id": "G.1.2",
      "title": "Organic farming",
      "category": "type_of_agriculture",
      "active_at_start": false,
      "description": "Specifications of organic farming rely mainly on no chemical input use. Input and output prices are 25% higher in conventional farming."
    },
